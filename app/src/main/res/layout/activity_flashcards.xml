<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <!-- Animated decorative orbs (like main menu) -->
    <View
        android:id="@+id/orbFlash1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-40dp"
        android:background="@drawable/bg_orb_purple"
        android:alpha="0.12" />

    <View
        android:id="@+id/orbFlash2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="-50dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_orb_teal"
        android:alpha="0.10" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header row with Back + Title + Save -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- Back button (left) -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="← Back"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:paddingHorizontal="4dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:clickable="true"
                android:focusable="true" />

            <!-- Title (center) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/flashcards_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />

            <!-- Save button (right) -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_save"
                android:text="💾  Save"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:visibility="gone"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Card counter -->
        <TextView
            android:id="@+id/tvCardCounter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Card 1 of X"
            android:gravity="center"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Flip Card Container -->
        <FrameLayout
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardFront"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@color/flashcard_front"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                android:layout_margin="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:background="@color/primary"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/tvFrontLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/term_label"
                        android:gravity="center"
                        android:textColor="@color/primary_light"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="20dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <TextView
                            android:id="@+id/tvTerm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="4dp"
                            android:text="Sample Term" />
                    </ScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@color/flashcard_back"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                android:layout_margin="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:background="@color/secondary"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/definition_label"
                        android:gravity="center"
                        android:textColor="@color/secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="20dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <TextView
                            android:id="@+id/tvDefinition"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="19sp"
                            android:lineSpacingExtra="6dp"
                            android:text="Sample Definition text goes here." />
                    </ScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <!-- Flip hint -->
        <TextView
            android:id="@+id/tvFlipHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tap_to_flip"
            android:gravity="center"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Multiple Choice Buttons (hidden in identification mode) -->
        <LinearLayout
            android:id="@+id/mcContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnChoiceA"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_choice_default"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:text="A. Choice"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnChoiceB"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_choice_default"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:text="B. Choice"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnChoiceC"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_choice_default"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:text="C. Choice"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnChoiceD"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_choice_default"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:text="D. Choice"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Score display (MC mode only) -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="54dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_glass"
                android:text="← Previous"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_primary"
                android:text="Next →"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Confetti overlay (invisible until Finish!) -->
    <FrameLayout
        android:id="@+id/confettiOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="100dp"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>