<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️"
                android:textSize="26sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_title"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 characters"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"
            android:paddingStart="42dp" />

        <!-- Edit Text with premium styling -->
        <EditText
            android:id="@+id/etExtractedText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_edittext_premium"
            android:gravity="top|start"
            android:hint="@string/extracted_text_will_appear_here"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:inputType="textMultiLine"
            android:padding="18dp"
            android:scrollbars="vertical"
            android:layout_marginBottom="20dp"
            android:fontFamily="monospace" />

        <!-- Mode Selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quiz Mode"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btnModeIdentify"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:background="@drawable/bg_mode_selected"
                android:gravity="center"
                android:text="📝 Identification"
                android:textColor="@color/text_on_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnModeMC"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:background="@drawable/bg_mode_unselected"
                android:gravity="center"
                android:text="🔘 Multiple Choice"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Generate Button -->
        <LinearLayout
            android:id="@+id/btnGenerateFlashcards"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_button">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="20sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/generate_flashcards"
                android:textColor="@color/text_on_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/primary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/generating"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI is analyzing your text..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>
</FrameLayout>