<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="end"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_orb_purple"
        android:alpha="0.2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan Notes"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose how to capture your notes"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginBottom="32dp" />

        <!-- Take Photo Card -->
        <LinearLayout
            android:id="@+id/cardCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_glass">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="📸"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_icon_circle"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/take_photo"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan documents with your camera"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Choose Image Card -->
        <LinearLayout
            android:id="@+id/cardGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_glass">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🖼️"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_icon_circle"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_image"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pick an image from your gallery"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Choose Document Card -->
        <LinearLayout
            android:id="@+id/cardDocument"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_glass">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="📄"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_icon_circle"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_document"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Import PDF or image files"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_glass"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</FrameLayout>